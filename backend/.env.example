DATABASE_URL=postgresql://user:password@localhost:5432/atomquest
SECRET_KEY=your-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=development

# Azure AD SSO (Bonus 5.1) — leave blank to disable
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_ADMIN_EMAILS=

# Email notifications via SendGrid (Bonus 5.2) — leave blank to disable
SENDGRID_API_KEY=
FROM_EMAIL=noreply@atomquest.com

# MS Teams adaptive card notifications (Bonus 5.2) — leave blank to disable
# Create an Incoming Webhook connector in your Teams channel and paste the URL here
TEAMS_WEBHOOK_URL=

FRONTEND_URL=http://localhost:5173
